<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    style="@style/style_list_item"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="4dp">

    <RelativeLayout
        android:id="@+id/list_item_generic_header"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_toStartOf="@id/list_item_generic_right"
        android:paddingEnd="0dp"
        android:paddingStart="0dp">

        <TextView
            android:id="@+id/list_item_generic_subtitle"
            style="@style/h2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentStart="true"
            android:gravity="start|center"
            android:maxLines="1"
            android:paddingEnd="0dp"
            android:paddingStart="0dp"
            android:text="-subtext-" />

        <TextView
            android:id="@+id/list_item_generic_date"
            style="@style/h2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:gravity="end|center"
            android:maxLines="1"
            android:paddingEnd="0dp"
            android:paddingStart="0dp"
            android:text="-date-" />
    </RelativeLayout>

    <RelativeLayout
        android:id="@+id/list_item_generic_primarybar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/list_item_generic_header"
        android:layout_toStartOf="@id/list_item_generic_right"
        android:paddingEnd="0dp"
        android:paddingStart="0dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingEnd="0dp"
            android:paddingStart="0dp">

            <ImageView
                android:id="@+id/list_item_picture"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentStart="true"
                android:contentDescription="TODO"
                android:gravity="start|center"
                android:paddingEnd="0dp"
                android:paddingStart="0dp" />

            <TextView
                android:id="@+id/list_item_generic_title"
                style="@style/h1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_toEndOf="@id/list_item_picture"
                android:gravity="start|center"
                android:maxLines="1"
                android:paddingEnd="4dp"
                android:paddingStart="4dp"
                android:text="-title-" />
        </RelativeLayout>
    </RelativeLayout>

    <RelativeLayout
        android:id="@+id/list_item_generic_right"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentEnd="true"
        android:layout_alignParentTop="true"
        android:paddingEnd="0dp"
        android:paddingStart="10dp">

        <include
            android:id="@+id/list_item_toggle"
            layout="@layout/button_toggle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="end|bottom"
            android:paddingEnd="0dp"
            android:paddingStart="0dp" />
    </RelativeLayout>

    <RelativeLayout
        android:id="@+id/list_item_generic_secondarybar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@+id/list_item_generic_primarybar"
        android:orientation="horizontal"
        android:paddingBottom="0dp"
        android:paddingEnd="0dp"
        android:paddingStart="0dp"
        android:paddingTop="0dp">

<!--        <ListView-->
<!--            android:id="@+id/testing"-->
<!--            android:layout_width="match_parent"-->
<!--            android:layout_height="wrap_content"-->
<!--            android:layout_below="@id/list_item_generic_overview"-->
<!--            android:paddingEnd="0dp"-->
<!--            android:paddingStart="20dp" />-->

        <!--        <TextView-->
        <!--            android:id="@+id/list_item_generic_overview"-->
        <!--            android:layout_width="wrap_content"-->
        <!--            android:layout_height="match_parent"-->
        <!--            android:layout_alignParentBottom="true"-->
        <!--            android:layout_below="@+id/settings_notification_day_offset"-->
        <!--            android:scrollbars="vertical"-->
        <!--            android:text="overview"-->
        <!--            android:textColor="@color/white" />-->

        <TextView
            android:id="@+id/list_item_generic_overview"
            style="@style/text"
            android:scrollbars="vertical"
            android:maxLines="4"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:paddingEnd="0dp"
            android:paddingStart="0dp"
            android:text="-overview-" />

    </RelativeLayout>

    <TextView
        android:id="@+id/list_item_generic_id"
        android:layout_width="0dp"
        android:layout_height="0dp" />
</RelativeLayout>
